# ──────────────────────────────────────────────
# AWS
# ──────────────────────────────────────────────
AWS_REGION=us-east-1
# As credenciais AWS devem ser configuradas via:
# - AWS CLI: aws configure
# - IAM Role (recomendado em produção)
# - Variáveis de ambiente: AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY

# ──────────────────────────────────────────────
# OCI
# ──────────────────────────────────────────────
OCI_TENANCY_OCID=ocid1.tenancy.oc1..example
OCI_USER_OCID=ocid1.user.oc1..example
OCI_FINGERPRINT=xx:xx:xx:xx:xx:xx:xx:xx
OCI_KEY_FILE=~/.oci/oci_api_key.pem
OCI_REGION=sa-saopaulo-1

# ──────────────────────────────────────────────
# GCP
# ──────────────────────────────────────────────
GCP_PROJECT_ID=my-project-id
GOOGLE_APPLICATION_CREDENTIALS=~/.gcp/service-account.json
GCP_BILLING_DATASET=my_dataset
GCP_BILLING_TABLE=my_billing_table

# ──────────────────────────────────────────────
# Thresholds de Ociosidade
# ──────────────────────────────────────────────
CPU_IDLE_THRESHOLD=5.0   # % médio de CPU para considerar instância ociosa
